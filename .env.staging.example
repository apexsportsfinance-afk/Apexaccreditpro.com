# ============================================================
# ApexAccreditPro — STAGING Environment Template
# ============================================================
# PURPOSE: build/run the app against the ISOLATED staging stack
#          (separate Supabase project + Stripe TEST mode). It must
#          NEVER contain a live value. See docs/STAGING_CLOUDFLARE.md.
#
# HOW TO USE:
#   - Cloudflare Pages (preferred): set these as env vars in the Pages
#     project (Production + Preview). Do NOT commit a filled-in copy.
#   - Local staging build: copy to .env.staging, fill in, then build.
#     (Vite bakes VITE_* into the bundle at BUILD time.)
#
# ISOLATION CONTRACT — none of these may equal a LIVE value:
#   LIVE Supabase (NEVER use here): dixelomafeobabahqeqg.supabase.co
#   LIVE domain   (NEVER assign):   accreditation.apexsports.ae
# If any value below matches the live column, STOP — it is not isolated.
# ============================================================

# --- SUPABASE (STAGING project only) ---
# From the NEW apex-staging project → Settings → API.
# The ref in the URL must NOT be the live ref above.
VITE_SUPABASE_URL=https://YOUR-STAGING-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-STAGING-anon-key-here

# --- SCANNER PIN (any test value) ---
VITE_SCANNER_PIN=0000

# --- Cloudflare Pages build ---
NODE_VERSION=20

# ============================================================
# NOTE: server.js (Express) and the Python medal parser do NOT run on
# Cloudflare Pages — so CORS_ALLOWED_ORIGINS / BRIDGE_* from .env.example
# are intentionally omitted here. Those paths are exercised only after the
# edge-function migration (docs/EDGE_MIGRATION.md).
# ============================================================

# Error tracking (rung 1). Create a Sentry React project, paste its DSN here, redeploy.
# The seam (src/lib/observability.js) lazy-loads @sentry/react ONLY when this is set; empty = console fallback.
# VITE_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# Medal parser cutover: true = use the parse-results edge fn instead of
# /api/bridge/results (server.js+medal_api.py). Flip ONLY after PDF parity passes.
# VITE_EDGE_MEDAL_PARSER=false
