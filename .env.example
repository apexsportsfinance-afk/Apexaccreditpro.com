# ============================================================
# ApexAccreditPro — Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file and rename the copy to: .env
#   2. Replace the placeholder values below with your real values
#   3. NEVER commit the .env file to GitHub — it is already in .gitignore
#   4. This .env.example file IS safe to commit (no real secrets here)
# ============================================================

# --- SUPABASE ---
# Your Supabase Project URL (found in: Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase Anon/Public Key (found in: Supabase Dashboard → Settings → API)
# This is the public anon key — it is safe to use in server.js with RLS enforced
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# --- SCANNER PIN ---
# The numeric PIN required to unlock the scanner page for gate staff
# If not set, the scanner falls back to the default "1234" (insecure — always set this!)
VITE_SCANNER_PIN=your-secure-pin-here

# ============================================================
# NOTES:
# - VITE_SUPABASE_URL is used by: server.js (Express API), src/lib/supabase.js (frontend)
# - VITE_SUPABASE_ANON_KEY is used by: server.js (Express API), src/lib/supabase.js (frontend)
# - The Express server (server.js) runs on port 3002 and reads .env at startup via dotenv
# - The Vite frontend reads VITE_* vars at build time from .env
# - Python bridge (scripts/medal_api.py) does NOT require any environment variables
# ============================================================
