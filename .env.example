# ============================================================
# ApexAccreditPro — Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file and rename the copy to: .env
#   2. Replace the placeholder values below with your real values
#   3. NEVER commit the .env file to GitHub — it is already in .gitignore
#   4. This .env.example file IS safe to commit (no real secrets here)
# ============================================================

# --- SUPABASE ---
# Your Supabase Project URL (found in: Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase Anon/Public Key (found in: Supabase Dashboard → Settings → API)
# This is the public anon key — it is safe to use in server.js with RLS enforced
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# --- SCANNER PIN ---
# The numeric PIN required to unlock the scanner page for gate staff.
# There is no insecure default — if unset, the scanner stays locked.
VITE_SCANNER_PIN=your-secure-pin-here

# --- API SERVER (server.js) ---
# Comma-separated list of browser origins allowed to call the Express API.
CORS_ALLOWED_ORIGINS=http://localhost:5180,http://localhost:5173,https://accreditation.apexsports.ae

# --- PYTHON BRIDGE (scripts/medal_api.py) ---
# Bind host for the medal parser. Keep as loopback unless behind a trusted network.
BRIDGE_HOST=127.0.0.1
# Comma-separated origins allowed to call the bridge.
BRIDGE_ALLOWED_ORIGINS=http://localhost:5180,http://localhost:5173,https://accreditation.apexsports.ae
# Set to 1 ONLY for local debugging to dump extracted PDF text (writes PII to disk).
# BRIDGE_DEBUG=0

# ============================================================
# NOTES:
# - VITE_SUPABASE_URL is used by: server.js (Express API), src/lib/supabase.js (frontend)
# - VITE_SUPABASE_ANON_KEY is used by: server.js (Express API), src/lib/supabase.js (frontend)
# - The Express server (server.js) runs on port 3002 and reads .env at startup via dotenv
# - The Vite frontend reads VITE_* vars at build time from .env
# - Python bridge (scripts/medal_api.py) does NOT require any environment variables
# ============================================================

# Error tracking (rung 1). Create a Sentry React project, paste its DSN here, redeploy.
# The seam (src/lib/observability.js) lazy-loads @sentry/react ONLY when this is set; empty = console fallback.
# VITE_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# Medal parser cutover: true = use the parse-results edge fn instead of
# /api/bridge/results (server.js+medal_api.py). Flip ONLY after PDF parity passes.
# VITE_EDGE_MEDAL_PARSER=false
