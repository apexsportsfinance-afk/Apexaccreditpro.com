# Copy to staging.tfvars and fill in. staging.tfvars is gitignored.
# STAGING is a SEPARATE Supabase project + SEPARATE keys from prod — it must
# never reference the live project ref or the production domain. See
# docs/STAGING_CLOUDFLARE.md and docs/DEPLOYMENT.md.
#
# Secrets (supabase_access_token, vercel_api_token, cloudflare_api_token) come
# from TF_VAR_* environment variables, NOT this file.

environment     = "staging"
region          = "eu-central-1"
app_domain      = "apex-staging.pages.dev"          # the *.pages.dev URL, NOT apexsports.ae
allowed_origins = ["https://apex-staging.pages.dev"]

# Non-secret resource identifiers — STAGING values only.
supabase_project_ref = "your-STAGING-project-ref"    # NOT the live ref
supabase_url         = "https://your-STAGING-project-ref.supabase.co"
cloudflare_zone_id   = "your-cloudflare-zone-id"     # only if using a custom staging zone
vercel_git_repo      = "your-org/apexaccreditpro"

# Secrets — DO NOT put here. Provide via environment:
#   TF_VAR_supabase_anon_key      (STAGING anon key)
#   TF_VAR_scanner_pin            (any test PIN)
#   TF_VAR_supabase_access_token, TF_VAR_vercel_api_token, TF_VAR_cloudflare_api_token
# function_secrets is injected via TF_VAR_function_secrets (JSON map) — use
# Stripe TEST keys for staging (sk_test_… / whsec_test_…), never live keys.
