{
  "name": "accreditation-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "server": "node server.js",
    "bridge": "python scripts/medal_api.py",
    "dev": "node \"./node_modules/concurrently/dist/bin/index.js\" \"npm run server\" \"npm run bridge\" \"node ./node_modules/vite/bin/vite.js --host\"",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\""
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3",
    "@supabase/supabase-js": "^2.97.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.16",
    "cors": "^2.8.6",
    "date-fns": "^2.30.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "face-api.js": "^0.22.2",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.18.2",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jaro-winkler": "^0.2.8",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jszip": "^3.10.1",
    "lucide-react": "^0.294.0",
    "multer": "^2.2.0",
    "pdfjs-dist": "^4.4.168",
    "postcss": "^8.4.31",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-is": "^19.2.7",
    "react-router-dom": "^6.20.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.3.0",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "node-fetch": "^2.7.0",
    "undici": "^7.16.0",
    "dompurify": "^2.5.9"
  }
}
